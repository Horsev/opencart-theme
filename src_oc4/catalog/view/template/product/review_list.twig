{% if reviews %}
	<div class="review-list mb-4">
		{% for review in reviews %}
			<article class="review-item pb-3 mb-3">
				<div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
					<strong class="review-author">{{ review.author }}</strong>
					<time class="text-muted small" datetime="{{ review.date_added }}">{{ review.date_added }}</time>
				</div>
				<div class="rating mt-1 mb-2">
					{% for i in 1..5 %}
						{% if review.rating < i %}
							<span class="opacity-25">
								{% include 'extension/playground_theme/catalog/view/template/icons/star-solid-full.twig' %}
							</span>
						{% else %}
							<span class="text-warning">
								{% include 'extension/playground_theme/catalog/view/template/icons/star-solid-full.twig' %}
							</span>
						{% endif %}
					{% endfor %}
				</div>
				<div class="review-text">{{ review.text|raw }}</div>
			</article>
		{% endfor %}
		<div class="text-end">{{ pagination|raw }}</div>
	</div>
{% else %}
	<p class="text-center mb-0">{{ text_no_results|default('There are no reviews for this product.') }}</p>
{% endif %}
