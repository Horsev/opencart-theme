{# Playground Theme: override product/thumb — product card in category/search/listings. #}
{# Picture uses OC cache sizes (40, 136, 250, 500, 800); display size from config_image_product or 250. Don't show image block for placeholder. #}
{% set _src = thumb_250|default(thumb) %}
{% set _has_sizes = thumb_40 is defined and thumb_40 and thumb_136 is defined and thumb_136 and thumb_250 is defined and thumb_250 and thumb_500 is defined and thumb_500 and thumb_800 is defined and thumb_800 %}
{% set _w = thumb_width|default(250) %}
{% set _h = thumb_height|default(250) %}
{% set _is_placeholder = _src and 'placeholder' in _src|lower %}
	<div class="product-thumb card h-100 border-0"> {% if _src and not _is_placeholder %}
		<div class="image">
			<a href="{{ href }}">
				{% if _has_sizes %}
					<picture>
						<img src="{{ _src }}" srcset="{{ thumb_40 }} 40w, {{ thumb_136 }} 136w, {{ thumb_250 }} 250w, {{ thumb_500 }} 500w, {{ thumb_800 }} 800w" sizes="(max-width: 576px) 136px, {{ _w }}px" alt="{{ name }}" title="{{ name }}" class="card-img-top img-fluid" loading="lazy" width="{{ _w }}" height="{{ _h }}">
					</picture>
				{% else %}
					<img src="{{ _src }}" alt="{{ name }}" title="{{ name }}" class="card-img-top img-fluid" loading="lazy" width="{{ _w }}" height="{{ _h }}">
				{% endif %}
			</a>
		</div>
	{% endif %}

	<div class="card-body vstack position-relative">
		<h4 class="card-title">
			<a href="{{ href }}" class="text-decoration-none stretched-link">{{ name }}</a>
		</h4>
		<p class="card-text">{{ description }}</p>
		<div class=" mb-0 mt-auto">
			{% if review_status and rating %}
				<div class="rating small text-warning mb-2">
					{% for i in 1..5 %}
						{% if rating < i %}
							<i class="fa-regular fa-star"></i>
						{% else %}
							<i class="fa-solid fa-star"></i>
						{% endif %}
					{% endfor %}
				</div>
			{% endif %}
			{% if price %}
				<div class="price">

					{% if not special %}
						<span class="price-new fs-4">{{ price }}</span>

					{% else %}
						<span class="price-new fs-4 fw-bold">{{ special }}</span>

						<span class="price-old fs-4 text-muted text-decoration-line-through small">{{ price }}</span>

					{% endif %}
					{% if tax %}
						<span class="price-tax d-block small text-muted">{{ text_tax }}
							{{ tax }}</span>
					{% endif %}
				</div>
			{% endif %}
		</div>

	</div>
	<div class="card-footer border-0 bg-body">
		<form method="post" data-oc-toggle="ajax" data-oc-load="{{ cart }}" data-oc-target="#header-cart-feather" class="mb-3">
			<div class="button-group btn-group border">
				<button type="submit" formaction="{{ add_to_cart }}" data-bs-toggle="tooltip" title="{{ button_cart }}" class="btn btn-primary">
					{% include 'extension/playground_theme/catalog/view/template/icons/cart_shopping_regular_full.twig' %}
				</button>
				<button type="submit" formaction="{{ add_to_wishlist }}" data-bs-toggle="tooltip" title="{{ button_wishlist }}" class="btn">
					{% include 'extension/playground_theme/catalog/view/template/icons/heart_regular_full.twig' %}
				</button>
				<button type="submit" formaction="{{ add_to_compare }}" data-bs-toggle="tooltip" title="{{ button_compare }}" class="btn">
					{% include 'extension/playground_theme/catalog/view/template/icons/arrow-right-arrow-left-regular-full.twig' %}
				</button>
			</div>
			<input type="hidden" name="product_id" value="{{ product_id }}"/>
			<input type="hidden" name="quantity" value="{{ minimum }}"/>
		</form>

	</div>
</div>
