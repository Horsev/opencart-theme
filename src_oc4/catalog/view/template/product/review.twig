<form id="form-review">
	<div id="review">
		{% if list|trim == '' %}
			<p class="text-center mb-0">{{ text_no_reviews|default('There are no reviews for this product.') }}</p>
		{% else %}
			{{ list|raw }}
		{% endif %}
	</div>
	<fieldset>
		<legend>{{ text_write }}</legend>
		{% if review_guest %}
			<div class="row g-1 mb-3 required">
				<div class="col-12 col-md-3">
					<label class="form-label">{{ entry_rating }}</label>
				</div>
				<div class="col-12 col-md-9">
					<div id="input-rating">
						{% for i in 1..5 %}
							<div class="form-check form-check-inline ps-0 me-0">
								<input type="radio" name="rating" id="star{{ i - 1 }}" value="{{ i }}" class="form-check-input" hidden/>
								<label class="form-check-label" for="star{{ i - 1 }}">
									<span data-oc-star="far">
										<i class="fa-star far"></i>
									</span>
									<span class="d-none" data-oc-star="fas">
										<i class="fa-star fas text-warning"></i>
									</span>
								</label>
							</div>
						{% endfor %}
					</div>
					<div id="error-rating" class="invalid-feedback"></div>
				</div>
			</div>

			<div class="row g-1 mb-3 required">
				<div class="col-12 col-md-3">
					<label class="form-label" for="input-name">{{ entry_name }}</label>
				</div>
				<div class="col-12 col-md-9">
					<input type="text" name="name" value="{{ customer_name }}" id="input-name" class="form-control"/>
					<div id="error-name" class="invalid-feedback"></div>
				</div>
			</div>

			<div class="row g-1 mb-3 required">
				<div class="col-12">
					<label class="form-label" for="input-text">{{ entry_review }}</label>
				</div>
				<div class="col-12">
					<textarea id="input-text" class="form-control" name="text" rows="3"></textarea>
					<div id="error-text" class="invalid-feedback"></div>
					<div class="invalid-feedback">
						<span class="text-danger">{{ text_note|default('Note:') }}</span>
						{{ text_html_not_translated|default('HTML is not translated!') }}
					</div>
				</div>
				<div class="col-12"></div>
			</div>
			{{ captcha }}
			<button type="submit" id="button-review" class="btn btn-primary">{{ button_continue }}</button>
		{% else %}
			{{ text_login }}
		{% endif %}
	</fieldset>
</form>
