{# Playground Theme: override product/manufacturer_list — use theme breadcrumb. #}
{{ header }}
{% include 'extension/playground_theme/catalog/view/template/common/breadcrumb.twig' with { breadcrumb_id: 'product-manufacturer-list' } %}

<div id="product-manufacturer" class="container">
	<div class="row">{{ column_left }}
		<div id="content" class="col">{{ content_top }}
			<section class="bg-body rounded p-5 mb-3">
				<h1>{{ heading_title }}</h1>
				{% if categories %}
					<p>
						<strong>{{ text_index }}</strong>
						{% for category in categories %}
							&nbsp;&nbsp;&nbsp;<a href="{{ category.href }}#{{ category.name }}">{{ category.name }}</a>
						{% endfor %}
					</p>
					{% for category in categories %}
						<h2 id="{{ category.name }}">{{ category.name }}</h2>
						{% if category.manufacturer %}
							{% for manufacturers in category.manufacturer|batch(4) %}
								<div class="row mb-3">
									{% for manufacturer in manufacturers %}
										<div class="col-sm-3">
											<a href="{{ manufacturer.href }}">{{ manufacturer.name }}</a>
										</div>
									{% endfor %}
								</div>
							{% endfor %}
						{% endif %}
					{% endfor %}
				{% else %}
					<p>{{ text_no_results }}</p>
					<div class="text-end">
						<a href="{{ continue }}" class="btn btn-primary">{{ button_continue }}</a>
					</div>
				{% endif %}
			</section>
			{{ content_bottom }}</div>
		{{ column_right }}</div>
</div>
{{ footer }}
